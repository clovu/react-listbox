{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/playground.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"],
      "react-listbox-primitives": ["../packages/listbox/node_modules/.tmp/types/index.d.ts"]
    },
    "types": ["vite/client", "node"],
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.tmp/types"
  },
  "references": [
    { "path": "../packages/listbox" }
  ],
  "include": ["src", "vite.config.ts"]
}
